{
    "compilerOptions": {
		"target": "es6",
		"lib": [
			"es6",
			"dom.iterable",
			"scripthost"
		],
		"noImplicitAny": true,
		"noImplicitThis": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strictPropertyInitialization": true,
        "removeComments": false,
        "preserveConstEnums": true,
    },
    "include": [
        "*"
    ]
}