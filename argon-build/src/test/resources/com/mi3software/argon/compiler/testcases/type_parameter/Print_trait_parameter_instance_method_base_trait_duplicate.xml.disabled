<ArgonTest>

    <Name>Print trait parameter instance method base trait duplicate</Name>


    <InputSource name="test.ar"><![CDATA[
            
        import Ar._
        
        trait MyTrait1(str: String) <: Any


            public proc _.printMessage(): () =
                puts str

        end

        trait MyTrait2(str: String) <: MyTrait1(str)
        end

        trait MyTrait3(str: String) <: MyTrait1(str)
        end

        trait MyTrait4(str: String) <: MyTrait2(str) & MyTrait3(str)
        end

        constructor MyCtor(str: String): MyTrait4(str)
        end
        
        proc main(): () do
            MyCtor('Hello World').printMessage()
        end
        
            
    ]]></InputSource>

    <ExpectedOutput>Hello World</ExpectedOutput>

</ArgonTest>
