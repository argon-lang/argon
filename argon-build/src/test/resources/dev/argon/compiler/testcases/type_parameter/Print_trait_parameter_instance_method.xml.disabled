<ArgonTest>

    <Name>Print trait parameter instance method</Name>


    <InputSource name="test.ar"><![CDATA[
            
        import Ar._
        
        trait MyTrait(str: String) <: Any


            public proc _.printMessage(): () =
                puts str

        end

        constructor MyCtor(str: String): MyTrait(str)
        end
        
        proc main(): () do
            MyCtor('Hello World').printMessage()
        end
        
            
    ]]></InputSource>

    <ExpectedOutput>Hello World</ExpectedOutput>

</ArgonTest>
